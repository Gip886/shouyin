# 装机前把本文件复制成 .env(注意是仓库根目录的 .env,不是 apps/api/.env),
# 按注释填。docker compose 会自动读取。
#
#   cp .env.docker.example .env
#
# 已经跑过一次 up 之后再改这里的 SEED_* 不会生效(entrypoint 只在库为空时 seed)。
# 想强制重置:docker compose down -v 清空 volume 再 up。

# ── 数据库账号(可以不改,反正只在 compose 内网可见) ────────
POSTGRES_USER=shouyin
POSTGRES_PASSWORD=shouyin
POSTGRES_DB=shouyin

# ── JWT 签名密钥,生产**必须**改 ────────────────────
# 生成:  openssl rand -base64 48
JWT_SECRET=change-me-please-openssl-rand-base64-48
JWT_EXPIRES_IN=12h

# ── 首次 seed 时给种子用户设的初始密码 ──────────────
SEED_ADMIN_PASSWORD=换成你想设的老板密码
SEED_CASHIER_PASSWORD=换成收银员的默认密码

# ── 对外端口(默认 3001) ──────────────────────────
API_PORT=3001
