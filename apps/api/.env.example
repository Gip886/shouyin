# 装机时把本文件复制成 .env,按下面注释填。

# ── 必填 ─────────────────────────────────────────────
# PostgreSQL 连接串。docker compose 默认 shouyin/shouyin,自己装 pg 就换成本机账号。
DATABASE_URL="postgresql://shouyin:shouyin@localhost:5432/shouyin?schema=public"

# JWT 签名密钥。生产**必须**改成随机长字符串,别用默认值。
# 生成一个:  openssl rand -base64 48   (Linux/Mac)
#            或者 https://randomkeygen.com 复制一个 512-bit 的
JWT_SECRET="dev-only-change-me-in-production"

# JWT 有效期:12h 是默认,足够一个班次。想更严就 2h,更宽松就 7d。
JWT_EXPIRES_IN="12h"

# HTTP 端口。3001 是默认,和其他常见服务冲突时改。
PORT=3001

# ── 装机时用一次(seed 阶段) ─────────────────────────
# 首次 `pnpm db:seed` 时,给种子用户设初始密码,免得留下 admin/admin123 默认口。
# 已经存在的用户不会被覆盖(避免运行中被意外重置);想强制重置密码,同时设
# SEED_FORCE_RESET_PASSWORD=1 再跑一次 db:seed。
# SEED_ADMIN_PASSWORD="装机时想设的老板密码"
# SEED_CASHIER_PASSWORD="装机时想设的收银员密码"
# SEED_FORCE_RESET_PASSWORD=1
